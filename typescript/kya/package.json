{
  "name": "@digitalforgestudios/kya-sdk",
  "version": "1.0.0",
  "description": "TypeScript/JavaScript SDK for the KYA (Know Your Agent) trust scoring system",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "kya",
    "know-your-agent",
    "pheme",
    "trust",
    "agent",
    "reputation",
    "sdk",
    "ai-agents",
    "ard"
  ],
  "author": "Digital Forge Studios Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalforgeca/kya-sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/digitalforgeca/kya-sdk-typescript/issues"
  },
  "homepage": "https://github.com/digitalforgeca/kya-sdk-typescript#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
